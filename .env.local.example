# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend
RESEND_API_KEY=your-resend-api-key
# One Resend segment per waitlist role; signups route by the Landlord/Tenant toggle.
RESEND_WAITLIST_LANDLORD_SEGMENT_ID=your-landlord-segment-id
RESEND_WAITLIST_TENANT_SEGMENT_ID=your-tenant-segment-id

# Anthropic (contract extraction)
# Required. Used by the contract extraction engine to call Claude via Vercel AI SDK.
# Generate at https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional. Defaults to claude-sonnet-4-6 if unset.
# Override to a cheaper model (e.g. claude-haiku-4-5-20251001) for experiments.
CONTRACT_EXTRACTION_MODEL=claude-sonnet-4-6

# Pluggy (Open Finance — bank account connection)
# Sandbox creds from https://dashboard.pluggy.ai → API Keys. Server-only;
# never expose CLIENT_SECRET to the browser. Production credentials are
# downstream of incorporation — sandbox only for now.
PLUGGY_CLIENT_ID=your-pluggy-client-id
PLUGGY_CLIENT_SECRET=your-pluggy-client-secret
